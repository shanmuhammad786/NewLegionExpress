<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" 
             xmlns:scanditCore="clr-namespace:Scandit.DataCapture.Core.UI.Unified;assembly=ScanditCaptureCoreUnified" xmlns:scanditBarcode="clr-namespace:Scandit.DataCapture.Barcode.UI.Unified;assembly=ScanditBarcodeCaptureUnified"
             x:Class="legionexpress.Views.DeliveryScanning">
    <ContentPage.Content>
        <AbsoluteLayout>

            <scanditCore:DataCaptureView 
                AbsoluteLayout.LayoutBounds="0,0,1,1"
                AbsoluteLayout.LayoutFlags="All"
                DataCaptureContext="{Binding DataCaptureContext}"
                    ScanAreaMargins="{Binding ScanAreaMargins}">
                <scanditBarcode:BarcodeCaptureOverlay 
                    BarcodeCapture="{Binding BarcodeCapture}"

                    Viewfinder="{Binding Viewfinder}"
                    Brush="{Binding HighlightingBrush}" />
            </scanditCore:DataCaptureView>
            <!--<Button Text="End Scanning"
                    WidthRequest="300"
                    HeightRequest="70"
                    AbsoluteLayout.LayoutBounds="0,0.85,1,0.1"
                    AbsoluteLayout.LayoutFlags="All"
                    BackgroundColor="#FF5E00"
                    TextColor="White"
                    CornerRadius="5"
                    Clicked="StopScanning_Clicked"
                    HorizontalOptions="Center" />-->
            <StackLayout   AbsoluteLayout.LayoutBounds="0.5,0,1,1"
                 AbsoluteLayout.LayoutFlags="All">
                <Frame Padding="40,15,40,15" HorizontalOptions="CenterAndExpand" Margin="30,5,30,0" CornerRadius="15">
                    <Label Text="Delivery Scan" FontSize="16" FontAttributes="Bold" TextColor="Black" HorizontalTextAlignment="Center"/>
                </Frame>
                <Frame Padding="40,15,40,10" HorizontalOptions="CenterAndExpand" Margin="30,5,30,0" CornerRadius="15">
                    <StackLayout>
                        <Label Text="Delivery Name" FontSize="16" FontAttributes="Bold" TextColor="Black" HorizontalTextAlignment="Center"/>
                        <Label Text="PostCode" Margin="0,10,0,0" FontSize="16" FontAttributes="Bold" TextColor="Black" HorizontalTextAlignment="Center"/>
                    </StackLayout>
                </Frame>
                <!--<Button Text="Warehouse Scan" IsEnabled="False" CornerRadius="10" Margin="40,0,40,0" BackgroundColor="White" TextColor="Black"  />-->
            </StackLayout>
            <StackLayout  AbsoluteLayout.LayoutBounds="0.8,0.45,0.9,0.1"
                    AbsoluteLayout.LayoutFlags="All">
                <Frame BackgroundColor="Black" HorizontalOptions="CenterAndExpand" CornerRadius="10" BorderColor="Orange">
                    <StackLayout>
                        <Label Text="Delivered" TextColor="White"/>
                    </StackLayout>
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding DeliveredCommand}"/>
                    </Frame.GestureRecognizers>
                </Frame>
            </StackLayout>
            <StackLayout  AbsoluteLayout.LayoutBounds="3,0.6,0.9,0.1"
                    AbsoluteLayout.LayoutFlags="All">
                <Frame BackgroundColor="Black" HorizontalOptions="CenterAndExpand" CornerRadius="10" BorderColor="Orange">
                    <StackLayout>
                        <Label Text="Check" TextColor="White"/>
                        <Label Text="Address" TextColor="White"/>
                    </StackLayout>
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CheckAddressCommand}"/>
                    </Frame.GestureRecognizers>
                </Frame>
            </StackLayout>
            <StackLayout  AbsoluteLayout.LayoutBounds="3,0.75,0.9,0.1"
                    AbsoluteLayout.LayoutFlags="All">
                <Frame BackgroundColor="Black" HorizontalOptions="CenterAndExpand" CornerRadius="10" BorderColor="Orange">
                    <StackLayout>
                        <Label Text="Other" TextColor="White"/>
                    </StackLayout>
                </Frame>
            </StackLayout>
            <StackLayout  AbsoluteLayout.LayoutBounds="0,0.6,0.5,0.1"
                    AbsoluteLayout.LayoutFlags="All">
                <Frame BackgroundColor="Black" HorizontalOptions="CenterAndExpand" CornerRadius="10" BorderColor="Orange">
                    <StackLayout>
                        <Label Text="Delivery" TextColor="White"/>
                        <Label Text="Attempted" TextColor="White"/>
                    </StackLayout>
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding AttemptedCommand}"/>
                    </Frame.GestureRecognizers>
                </Frame>
            </StackLayout>
            <StackLayout  AbsoluteLayout.LayoutBounds="0,0.75,0.5,0.1"
                    AbsoluteLayout.LayoutFlags="All">
                <Frame BackgroundColor="Black" HorizontalOptions="CenterAndExpand" CornerRadius="10" BorderColor="Orange">
                    <StackLayout>
                        <Label Text="Refused" TextColor="White"/>
                    </StackLayout>
                </Frame>
            </StackLayout>
            <StackLayout  AbsoluteLayout.LayoutBounds="0,0.90,1,0.1"
                    AbsoluteLayout.LayoutFlags="All">
                <Button Text="Stop Scanning" Command="{Binding StopScanningCommand}" CornerRadius="10" Margin="40,0,40,0" BackgroundColor="White" TextColor="Black"  />
            </StackLayout>
            <StackLayout Orientation="Horizontal" WidthRequest="300" Margin="50,0"
                    AbsoluteLayout.LayoutBounds="0,0.99,1,0.1"
                    AbsoluteLayout.LayoutFlags="All"
                    BackgroundColor="Transparent">
                <Image Source="back" HeightRequest="30" Margin="20,0">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer/>
                    </Image.GestureRecognizers>
                </Image>
                <Image Source="scan" HeightRequest="50" Margin="20,0">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ScanEnableCommand}"/>
                    </Image.GestureRecognizers>
                </Image>
                <Image Source="information" HeightRequest="25" Margin="20,0" IsVisible="{Binding AmendmendVisibility}">
                    <Image.GestureRecognizers >
                        <TapGestureRecognizer />
                    </Image.GestureRecognizers>
                </Image>
            </StackLayout>
            <!--<Button Text="Cancel"
                    WidthRequest="300"
                    AbsoluteLayout.LayoutBounds="0,0.99,1,0.1"
                    AbsoluteLayout.LayoutFlags="All"
                    BackgroundColor="Transparent"
                    BorderColor="White"
                    BorderWidth="1"
                    TextColor="White"
                    CornerRadius="5"
                        Clicked="OnCancel_Clicked"
                    HorizontalOptions="Center" />-->
        </AbsoluteLayout>
    </ContentPage.Content>
</ContentPage>