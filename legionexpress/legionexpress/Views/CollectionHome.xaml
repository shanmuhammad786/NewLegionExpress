<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="legionexpress.Views.CollectionHome"
             BackgroundColor="Black"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="70,*,70">

        <!-- Top Chevrons -->
        <Image Grid.Row="0"
               Source="StraightChevrons"
               HeightRequest="50"
               Margin="0,15"
               HorizontalOptions="Center">
            <!--<Image.GestureRecognizers>
                <TapGestureRecognizer Tapped="Logout_Tapped"/>
            </Image.GestureRecognizers>-->
        </Image>

        <!-- Center Card -->
        <Grid Grid.Row="1"
              HorizontalOptions="Center"
              VerticalOptions="Center">

            <Frame WidthRequest="320"
                   Padding="20"
                   CornerRadius="18"
                   BackgroundColor="#121212"
                   BorderColor="#2C2C2C"
                   HasShadow="True">

                <StackLayout Spacing="14">

                    <!-- White Button -->
                    <Button Text="COLLECTION + DELIVERY LIST"
                            BackgroundColor="White"
                            TextColor="Black"
                            HeightRequest="48"
                            CornerRadius="10"
                            FontSize="14"
                            FontAttributes="Bold"
                            Command="{Binding ColDelListCommand}" />

                    <!-- Dark Buttons -->
                    <Button Text="COLLECTION SCAN"
                            BackgroundColor="#2E2E2E"
                            TextColor="White"
                            HeightRequest="48"
                            CornerRadius="10"
                            FontSize="13"
                            BorderColor="#3A3A3A"
                            BorderWidth="0.5"
                            FontAttributes="Bold"
                            Command="{Binding CollectionCommand}" />

                    <Button Text="WAREHOUSE SCAN"
                            BackgroundColor="#2E2E2E"
                            TextColor="White"
                            HeightRequest="48"
                            CornerRadius="10"
                            FontSize="13"
                            FontAttributes="Bold"
                            BorderColor="#3A3A3A"
                            BorderWidth="0.5"
                            Command="{Binding WarehouseCommand}" />

                    <Button Text="DELIVERY SCAN"
                            BackgroundColor="#2E2E2E"
                            TextColor="White"
                            HeightRequest="48"
                            CornerRadius="10"
                            FontSize="13"
                            BorderColor="#3A3A3A"
                            FontAttributes="Bold"
                            BorderWidth="0.5"
                            Command="{Binding DeliveryScanCommand}" />

                    <!-- Divider -->
                    <BoxView HeightRequest="1"
                             BackgroundColor="#2C2C2C"
                             Margin="0,10"/>

                    <!-- Bottom Buttons -->
                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="12">

                        <Button Grid.Column="0"
                                Text="CANCEL"
                                BackgroundColor="#2E2E2E"
                                TextColor="White"
                                HeightRequest="48"
                                CornerRadius="10"
                                FontSize="13"
                                BorderColor="#3A3A3A"
                                BorderWidth="0.5"/>

                        <Button Grid.Column="1"
                                Text="LOGOUT"
                                BackgroundColor="#8B1E1E"
                                TextColor="White"
                                HeightRequest="48"
                                CornerRadius="10"
                                FontSize="13"
                                Clicked="Logout_Clicked"/>
                    </Grid>

                </StackLayout>
            </Frame>
        </Grid>

        <!-- Bottom Scan Icon -->
        <Image Grid.Row="2"
               Source="scan"
               HeightRequest="60"
               Margin="0,15"
               HorizontalOptions="Center"
               VerticalOptions="End">
            <Image.GestureRecognizers>
                <TapGestureRecognizer Tapped="Scan_Clicked"/>
            </Image.GestureRecognizers>
        </Image>

    </Grid>
</ContentPage>
